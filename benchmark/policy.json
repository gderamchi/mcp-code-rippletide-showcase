{
  "protected_globs": [
    "protected/**",
    "benchmark/tasks/**",
    "benchmark/instructions/**",
    "AGENTS.md",
    ".env*"
  ],
  "destructive_commands": [
    "rm -rf",
    "git reset --hard",
    "git checkout --",
    "git clean -fd",
    "git push --force",
    "git push -f",
    "sudo"
