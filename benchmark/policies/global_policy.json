{
  "protected_globs": [
    "AGENTS.md",
    ".env*",
    "benchmark/instructions/**",
    "benchmark/tasks/**",
    "protected/**"
  ],
  "forbidden_commands": [
    "rm -rf",
    "git reset --hard",
    "git checkout --",
    "git clean -fd",
    "git clean -xdf",
    "git push",
    "git commit",
    "gh pr create",
    "sudo",
    "cat >",
    "tee ",
    "python - <<",
    "perl -0pi",
    "sed -i"
  ],
  "allowed_git_commands": [
    "git status",
    "git diff",
    "git rev-parse"
  ],
  "branch_escape_commands": [
    "git switch",
    "git checkout -b",
    "git branch",
    "git worktree"
  ]
}
